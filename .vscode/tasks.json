{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C++",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "if exist \"${workspaceFolder}/output/${fileBasenameNoExtension}.exe\" del \"${workspaceFolder}/output/${fileBasenameNoExtension}.exe\" && g++ \"${file}\" -o \"${workspaceFolder}/output/${fileBasenameNoExtension}.exe\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}